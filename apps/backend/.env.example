DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.mogtigntgzjqihckjfyf.supabase.co:5432/postgres?sslmode=require

# Supabase (Storage y APIs)
SUPABASE_URL=https://mogtigntgzjqihckjfyf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=bio-call-pdfs

