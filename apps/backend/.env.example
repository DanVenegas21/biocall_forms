# Puerto del servidor de la API.
PORT=4000

# Origen permitido para CORS (frontend).
CORS_ORIGIN=http://localhost:3000

# PostgreSQL / Supabase (Prisma) — Session pooler (IPv4/IPv6, todo el equipo).
# Reemplaza [YOUR-PASSWORD] con la contraseña en Project Settings → Database.
# No uses la conexion directa (db....supabase.co): solo funciona en redes IPv6.
DATABASE_URL=postgresql://postgres.mogtigntgzjqihckjfyf:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# Supabase (Storage y APIs)
SUPABASE_URL=https://mogtigntgzjqihckjfyf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=bio-call-pdfs

# Ruta al logo para el PDF (opcional)
# LOGO_PATH=../frontend/public/LOGOTIPO_MANUEL_SOLIS_02.png

# Carpeta local de PDFs cuando Supabase Storage no esta configurado
# LOCAL_PDF_STORAGE_DIR=.data/pdfs
