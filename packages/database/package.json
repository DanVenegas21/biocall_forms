{
  "name": "@biocall/database",
  "version": "0.1.0",
  "private": true,
  "description": "Capa de datos: Prisma, migraciones y cliente de base de datos.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@biocall/shared": "*",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@biocall/config": "*",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
